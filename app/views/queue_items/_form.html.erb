<%# queue_items/_form.html.erb — YouTube URL add track form %>
<div class="card-elevated">
  <h3 class="font-semibold text-sm mb-3" style="color: var(--text-muted);">
    Adicionar música <span class="tag ml-1">YouTube URL</span>
  </h3>
  <%= form_with url: room_queue_items_path(room.slug),
                method: :post,
                data: { turbo: true },
                class: "flex gap-2" do %>
    <input type="url"
           name="url"
           placeholder="https://www.youtube.com/watch?v=..."
           class="input flex-1 text-sm"
           required>
    <button type="submit" class="btn btn-success shrink-0">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
      </svg>
      <span class="hidden sm:inline">Adicionar</span>
    </button>
  <% end %>
</div>
