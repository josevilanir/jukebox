<%# queue_items/_form.html.erb — YouTube URL add track form %>
<div class="card-elevated relative overflow-visible" 
     data-controller="youtube-search"
     data-youtube-search-url-value="<%= room_search_path(room.slug) %>">
  <h3 class="font-semibold text-sm mb-3" style="color: var(--text-muted);">
    Adicionar música <span class="tag ml-1">YouTube</span>
  </h3>
  
  <%= form_with url: room_queue_items_path(room.slug),
                method: :post,
                data: { turbo: true, action: "submit->youtube-search#preventFormSubmit" },
                class: "flex gap-2 relative z-10" do %>
    <div class="flex-1 relative">
      <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
        <svg class="w-4 h-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
      </div>
      <input type="text"
             name="url"
             placeholder="Busque por música, artista ou cole a URL..."
             class="input w-full text-sm placeholder:opacity-50 pl-10"
             required
             autocomplete="off"
             data-youtube-search-target="input"
             data-action="input->youtube-search#perform keydown->youtube-search#preventSubmit">
    </div>
    <button type="submit" class="btn btn-success shrink-0" data-action="click->youtube-search#allowSubmit">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
      </svg>
      <span class="hidden sm:inline">Adicionar</span>
    </button>
  <% end %>

  <%# Container for turbo stream search results %>
  <div id="search-results" 
       data-youtube-search-target="results" 
       class="absolute top-full left-0 z-50 w-[calc(100%-100px)] lg:w-full bg-[#18181b]/95 backdrop-blur-xl border border-white/10 shadow-2xl rounded-b-xl mt-1 max-h-[400px] overflow-y-auto">
  </div>
</div>
