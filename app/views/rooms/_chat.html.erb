<%# rooms/_chat.html.erb — dark floating chat panel %>
<div class="card flex flex-col h-[50vh] lg:h-[600px] overflow-y-auto">
  <h2 class="font-bold text-base mb-3">Chat</h2>

  <%# Messages list %>
  <div id="messages"
       class="flex-1 overflow-y-auto space-y-3 pr-1 scroll-area"
       data-controller="chat-scroll">
    <% room.messages.order(created_at: :asc).each do |m| %>
      <%= render "messages/message", message: m %>
    <% end %>
  </div>

  <div class="divider"></div>

  <%# Message form %>
  <%= form_with url: room_messages_path(room.slug),
                data: { turbo: true, controller: "reset-form", action: "turbo:submit-end->reset-form#reset" },
                class: "flex gap-2" do %>
    <input type="text"
           name="content"
           placeholder="Mensagem..."
           autocomplete="off"
           class="input text-sm flex-1"
           required>
    <button type="submit" class="btn btn-primary btn-sm px-4">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
      </svg>
    </button>
  <% end %>
</div>
