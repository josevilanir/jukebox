<%# rooms/new.html.erb — dark create room form %>
<% content_for :title, "Criar sala · Jukebox" %>

<div class="max-w-md mx-auto py-16 animate-fade-up">
  <div class="card">
    <h1 class="text-2xl font-extrabold mb-1">Criar sala</h1>
    <p class="text-sm mb-6" style="color: var(--text-muted);">
      Dê um nome e compartilhe o código com seus amigos.
    </p>

    <%= form_with model: @room do |f| %>
      <% if @room.errors.any? %>
        <div class="mb-4 px-4 py-2 rounded-lg border border-red-500/40 text-red-300 bg-red-500/10 text-sm">
          <%= @room.errors.full_messages.first %>
        </div>
      <% end %>
      <div class="space-y-4">
        <div>
          <%= f.label :name, "Nome da sala", class: "block text-sm font-medium mb-1.5" %>
          <%= f.text_field :name,
                placeholder: "ex: Pré-show dos amigos",
                class: "input",
                autofocus: true %>
        </div>
        <%= f.submit "Criar sala", class: "btn btn-primary w-full py-3 mt-2 text-base" %>
      </div>
    <% end %>
  </div>
</div>
