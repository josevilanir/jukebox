<%# rooms/_player.html.erb — glassmorphism Now Playing hero %>
<% queue_items = local_assigns.fetch(:queue_items) { room.queue_open } %>
<% current = local_assigns.fetch(:current_item) { room.now_playing } %>

<div id="player" class="card-elevated overflow-hidden">
  <% if current&.track&.youtube_id %>
    <%# Now playing hero with glassmorphism meta bar %>
    <div class="relative"
         data-controller="yt-player"
         data-yt-player-video-id-value="<%= current.track.youtube_id %>"
         data-yt-player-room-slug-value="<%= room.slug %>"
         data-yt-player-started-at-value="<%= current.started_at&.to_i || 0 %>"
         data-yt-player-server-time-value="<%= Time.current.to_f %>">
      <%= render "rooms/player_seek", started_at: current.started_at&.to_i || 0 %>
      <div data-yt-player-target="container" class="w-full aspect-video bg-black rounded-lg overflow-hidden relative">
        <div id="yt-player-placeholder" class="absolute inset-0 w-full h-full"></div>
      </div>

      <%# Meta overlay at bottom of player %>
      <div class="glass mt-0 rounded-b-xl px-4 py-3 -mt-1 flex items-center gap-3 flex-wrap">
        <div class="flex-1 min-w-0">
          <div class="font-semibold text-sm truncate"><%= current.track.title %></div>
          <div class="text-xs truncate" style="color: var(--text-muted);">
            Adicionado por <%= current.added_by.name %>
          </div>
        </div>
        <span class="badge badge-live animate-pulse-glow">
          <span class="live-dot mr-1"></span> Tocando
        </span>

        <%# Rewind / Forward — visíveis apenas para o host via CSS %>
        <button type="button"
                data-action="click->yt-player#rewind"
                class="btn btn-sm btn-ghost host-only"
                title="Voltar 15 segundos">
          ⏪ -15s
        </button>
        <button type="button"
                data-action="click->yt-player#forward"
                class="btn btn-sm btn-ghost host-only"
                title="Avançar 15 segundos">
          +15s ⏩
        </button>

        <%# Botão de skip vote %>
        <% user_voted = current.skip_votes.exists?(user: current_user) %>
        <% skip_count = current.skip_votes.count %>
        <% present_count = [PresenceChannel.user_count(room.slug), 1].max %>
        <% threshold = [(present_count * 0.5).ceil, 2].max %>
        <%= button_to(
              room_queue_item_skip_votes_path(room.slug, current),
              method: :post,
              class: "btn btn-sm #{user_voted ? 'btn-ghost opacity-50 cursor-not-allowed' : 'btn-ghost hover:text-yellow-400'}",
              disabled: user_voted,
              title: "Votar para pular"
            ) do %>
          ⏭ Pular
          <span class="ml-1 text-xs opacity-70"><%= skip_count %>/<%= threshold %></span>
        <% end %>

        <%# Botão Próxima — visível quando pode avançar %>
        <% if queue_items.length > 1 && room.can_advance?(current_user) %>
          <%= button_to "▶ Próxima", play_next_room_path(room.slug),
                method: :post,
                class: "btn btn-success btn-sm" %>
        <% end %>
      </div>
    </div>
  <% else %>
    <%# Empty player state %>
    <div class="flex flex-col items-center justify-center py-14 text-center">
      <div class="text-6xl mb-4 opacity-30">🎵</div>
      <p class="font-semibold text-lg mb-1">A pista está vazia!</p>
      <p class="text-sm" style="color: var(--text-muted);">Adicione a primeira música abaixo ↓</p>
      <% if queue_items.any? && room.can_advance?(current_user) %>
        <%= button_to "⏭ Iniciar", play_next_room_path(room.slug),
              method: :post,
              class: "btn btn-success mt-6" %>
      <% end %>
    </div>
  <% end %>
</div>
