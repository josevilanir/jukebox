<%# rooms/show.html.erb ─ premium dark-mode room view %>
<%= turbo_stream_from @room %>

<% content_for :title, "#{@room.name} · Jukebox" %>

<% content_for :nav_actions do %>
  <div class="flex items-center gap-3">
    <div class="hidden sm:flex items-center gap-2 text-sm" style="color: var(--text-muted);">
      <span class="font-semibold" style="color: var(--text-primary);"><%= current_user.name %></span>
      <% if @room.host?(current_user) %>
        <span class="badge badge-host">Host</span>
      <% end %>
    </div>
    <button
      onclick="navigator.clipboard.writeText(window.location.href).then(()=>this.textContent='Copiado ✓')"
      class="btn btn-ghost btn-sm font-mono">
      <%= @room.slug %>
    </button>
  </div>
<% end %>

<div class="py-5 space-y-5 animate-fade-up">

  <%# ─ Room Header ──────────────────────────────────────────────── %>
  <div
    class="flex items-center gap-3 flex-wrap"
    data-controller="presence"
    data-presence-slug-value="<%= @room.slug %>">

    <span class="live-dot"></span>
    <h1 class="text-2xl font-extrabold tracking-tight"><%= @room.name %></h1>

    <%# DJ Mode badge %>
    <% if @room.dj_mode? %>
      <span class="badge" style="background: rgba(251,191,36,0.15); color: #fbbf24; border-color: rgba(251,191,36,0.3);">
        🎛 Modo DJ
      </span>
    <% elsif !@room.host_online? %>
      <span class="badge" style="background: rgba(156,163,175,0.1); color: #9ca3af; border-color: rgba(156,163,175,0.2);">
        🎛 Modo DJ (auto)
      </span>
    <% end %>

    <div class="ml-auto flex items-center gap-3">
      <%# Contador de presença %>
      <span
        data-presence-target="count"
        class="text-sm"
        style="color: var(--text-muted);">
        1 pessoa ouvindo
      </span>

      <span class="badge badge-live"><%= @room.queue_open.length %> na fila</span>

      <%# Toggle DJ Mode — apenas host %>
      <% if @room.host?(current_user) %>
        <%= button_to(
              toggle_dj_mode_room_path(@room.slug),
              method: :patch,
              class: "btn btn-sm btn-ghost"
            ) do %>
          <%= @room.dj_mode? ? "🔒 Desligar Modo DJ" : "🎛 Ligar Modo DJ" %>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# ─ Player hero ──────────────────────────────────────────────── %>
  <%= render "rooms/player", room: @room %>

  <%# ─ Add track ────────────────────────────────────────────────── %>
  <%= render "queue_items/form", room: @room %>

  <%# ─ Main grid ────────────────────────────────────────────────── %>
  <div class="grid lg:grid-cols-3 gap-5">

    <%# Queue + History %>
    <div class="lg:col-span-2 space-y-5">
      <div id="queue"><%= render "rooms/queue", room: @room %></div>
      <%= render "rooms/history", room: @room %>
    </div>

    <%# Chat %>
    <div>
      <%= render "rooms/chat", room: @room %>
    </div>

  </div>
</div>
