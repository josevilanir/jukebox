<div class="max-w-3xl mx-auto p-6">
  <h1 class="text-3xl font-bold mb-4">Salas</h1>

  <div class="mb-4">
    <%= link_to "Criar nova sala", new_room_path, class: "px-4 py-2 bg-indigo-600 text-white rounded" %>
  </div>

  <ul class="space-y-2">
    <% @rooms.each do |room| %>
      <li>
        <%= link_to room.name, room_path(room.slug), class: "text-indigo-700 underline" %>
      </li>
    <% end %>
  </ul>
</div>
